# Supabase session pooler (IPv4). user is postgres.<project_ref>.
# Note: new projects use the aws-1-<region> pooler host (not aws-0).
DATABASE_URL=postgresql+psycopg://postgres.[PROJECT]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres

# WARNING: the test suite's autouse fixtures DELETE rows. TEST_DATABASE_URL MUST
# point at a SEPARATE throwaway database — never the same value as DATABASE_URL.
# tests/conftest.py refuses to run if it's empty or equal to DATABASE_URL.
TEST_DATABASE_URL=postgresql+psycopg://postgres.[TEST_PROJECT]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres

# AI provider: groq (cloud, free) or ollama (local)
AI_PROVIDER=groq
GROQ_API_KEY=changeme
GROQ_MODEL=llama-3.3-70b-versatile
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:4b

GEMINI_API_KEY=changeme
STORAGE_DIR=./data/files
APP_VERSION=0.1.0

# Self-hosted Langfuse tracing (optional). Leave blank to disable.
# HOST MUST be local — never cloud.langfuse.com; traces contain medical prompts.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001
