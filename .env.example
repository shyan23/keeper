# Supabase session pooler (IPv4). user is postgres.<project_ref>.
# Note: new projects use the aws-1-<region> pooler host (not aws-0).
DATABASE_URL=postgresql+psycopg://postgres.[PROJECT]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres
TEST_DATABASE_URL=postgresql+psycopg://postgres.[PROJECT]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres

# AI provider: groq (cloud, free) or ollama (local)
AI_PROVIDER=groq
GROQ_API_KEY=changeme
GROQ_MODEL=llama-3.3-70b-versatile
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:4b

GEMINI_API_KEY=changeme
STORAGE_DIR=./data/files
APP_VERSION=0.1.0
